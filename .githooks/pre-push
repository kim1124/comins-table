#!/bin/sh
set -eu

fail() {
  printf '%s\n' 'sensitive-data-check: failed' >&2
  exit 1
}

gitleaks_version=$(gitleaks version 2>/dev/null) || fail
[ "$gitleaks_version" = '8.30.1' ] || fail
gitleaks_output=$(mktemp "${TMPDIR:-/tmp}/comins-gitleaks.XXXXXX") || fail
trap 'rm -f "$gitleaks_output"' EXIT HUP INT TERM

while read -r local_ref local_sha remote_ref remote_sha; do
  if printf '%s' "$local_sha" | grep -Eq '^0+$'; then
    continue
  fi
  if printf '%s' "$remote_sha" | grep -Eq '^0+$'; then
    base_sha=$(git merge-base "$local_sha" refs/remotes/origin/main 2>/dev/null) || fail
  else
    base_sha=$remote_sha
  fi

  node scripts/check-public-identities.mjs "$base_sha" "$local_sha" >/dev/null 2>&1 || fail
  : >"$gitleaks_output"
  gitleaks git \
    --config .gitleaks.toml \
    --log-opts="$base_sha..$local_sha" \
    --redact \
    --ignore-gitleaks-allow \
    --no-banner \
    --no-color \
    --log-level error \
    >"$gitleaks_output" 2>&1 || fail
done
