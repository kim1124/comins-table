#!/bin/sh
set -eu

fail() {
  printf '%s\n' 'sensitive-data-check: failed' >&2
  exit 1
}

npm run check:hygiene -- --staged >/dev/null 2>&1 || fail
node scripts/check-public-identities.mjs >/dev/null 2>&1 || fail

gitleaks_version=$(gitleaks version 2>/dev/null) || fail
[ "$gitleaks_version" = '8.30.1' ] || fail

gitleaks_output=$(mktemp "${TMPDIR:-/tmp}/comins-gitleaks.XXXXXX") || fail
trap 'rm -f "$gitleaks_output"' EXIT HUP INT TERM

gitleaks git --pre-commit \
  --staged \
  --redact \
  --ignore-gitleaks-allow \
  --no-banner \
  --no-color \
  --log-level error \
  >"$gitleaks_output" 2>&1 || fail
